# ── Supabase (requeridas) ──────────────────────────────────
# Las sacás de: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Sesión de alumnos (requerida) ──────────────────────────
# Secreto para firmar las cookies de sesión. Generá uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── URL pública de la app ──────────────────────────────────
# En local: http://localhost:3000 — en Vercel: https://tu-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Integraciones futuras (opcionales, dejar vacías por ahora) ──
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
RESEND_API_KEY=
